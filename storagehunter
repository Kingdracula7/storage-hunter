-- ========== DRAG GUI (IMPROVED) ==========
local isDragging = false
local dragStart = Vector2.new()
local startPosition = Vector2.new()

-- Fungsi untuk update posisi frame
local function updateFramePosition(mousePos)
    local newX = mousePos.X - dragStart.X + startPosition.X
    local newY = mousePos.Y - dragStart.Y + startPosition.Y
    
    -- Batasi agar tidak keluar layar
    local screenSize = player:GetMouse().ViewSizeX or 1920
    local screenHeight = player:GetMouse().ViewSizeY or 1080
    local frameWidth = 250
    local frameHeight = 320  -- Diperbesar
    
    newX = math.max(0, math.min(newX, screenSize - frameWidth))
    newY = math.max(0, math.min(newY, screenHeight - frameHeight))
    
    frame.Position = UDim2.new(0, newX, 0, newY)
end

-- Mulai drag
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        -- Cek apakah yang diklik adalah button
        local guiService = game:GetService("GuiService")
        local mousePos = input.Position
        local object = guiService:GetGuiObjectAtPosition(mousePos)
        
        if object then
            if object:IsA("TextButton") or object:IsA("ImageButton") then
                return -- Jangan drag kalo klik button
            end
        end
        
        isDragging = true
        dragStart = input.Position
        startPosition = Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset)
    end
end)

-- Drag movement (lebih smooth)
userInput.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        updateFramePosition(input.Position)
    end
end)

-- Stop drag
userInput.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = false
    end
end)

