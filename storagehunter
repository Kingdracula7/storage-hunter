        promptConnections = {}
    end
    
    if isAutoBid then
        if autoBidLoop then
            autoBidLoop:Disconnect()
            autoBidLoop = nil
        end
        if autoBidCoroutine then
            coroutine.close(autoBidCoroutine)
            autoBidCoroutine = nil
        end
        isAutoBid = false
    end
    
    if humanoid then
        humanoid.WalkSpeed = 16
    end
    
    screenGui:Destroy()
end)

