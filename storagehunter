-- ========== FUNGSI AUTO BID ==========
local function toggleAutoBid()
    isAutoBid = not isAutoBid
    
    if isAutoBid then
        -- Matikan loop lama jika ada
        if autoBidLoop then
            autoBidLoop:Disconnect()
            autoBidLoop = nil
        end
        if autoBidCoroutine then
            coroutine.close(autoBidCoroutine)
            autoBidCoroutine = nil
        end
        
        -- Mulai auto bid dengan coroutine (jeda 0.3 detik)
        autoBidCoroutine = coroutine.create(function()
            while isAutoBid do
                pcall(function()
                    local replicatedStorage = game:GetService("ReplicatedStorage")
                    local auctionEvent = replicatedStorage:FindFirstChild("Events")
                    if auctionEvent then
                        auctionEvent = auctionEvent:FindFirstChild("Auction")
                        if auctionEvent then
                            auctionEvent = auctionEvent:FindFirstChild("Bid")
                            if auctionEvent then
                                auctionEvent:FireServer()
                            end
                        end
                    end
                end)
                task.wait(0.3)
            end
        end)
        coroutine.resume(autoBidCoroutine)
        
        autoBidBtn.Text = "💰 On"
        autoBidBtn.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
    else
        -- Hentikan auto bid
        if autoBidLoop then
            autoBidLoop:Disconnect()
            autoBidLoop = nil
        end
        if autoBidCoroutine then
            coroutine.close(autoBidCoroutine)
            autoBidCoroutine = nil
        end
        autoBidBtn.Text = "💰 Auto Bid"
        autoBidBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
    end
end

autoBidBtn.MouseButton1Click:Connect(toggleAutoBid)

